{
  "manifest_version": 3,
  "name": "LuiZa Transcrição",
  "description": "Transcreve vídeos do YouTube usando IA",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
