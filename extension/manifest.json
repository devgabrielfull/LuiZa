{
  "manifest_version": 3,
  "name": "LuiZa - YouTube para Texto",
  "version": "1.0.0",
  "description": "Transcreve vídeos do YouTube automaticamente usando IA da OpenAI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject-panel.js", "styles.css"],
      "matches": ["*://www.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
